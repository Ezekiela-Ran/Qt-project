#card {
    border: none;
    border-radius: 8px;
    background-color: #7AB893;
}

QPushButton#deleteRecordButton {
    background-color: #2F5A8F;
    color: white;
    padding: 5px 10px;
    border: none;
    border-radius: 4px;
}

QPushButton#deleteRecordButton:hover {
    background-color: #1E3F61;
}

QLineEdit#invoiceInput,
QDateEdit#invoiceDateInput {
    font-family: "Times New Roman";
    background-color: #FFFFFF;
    color: #032429;
}
